#include <iostream>
using namespace std;
int main() {
    int a[5];
    int m1,m2;
    cout << "Enter 5 numbers:\n";
    for(int i = 0; i < 5; i++)
        cin >> a[i];
    m1=m2 = -999999;
    for(int i = 0; i < 5; i++) {
        if(a[i] > m1) {
            m2=m1;
            m1 = a[i];
        }
        else if(a[i] > m2 && a[i] != m1) {
            m2 = a[i];
        }
    }
    cout << "m1 = " << m1 << endl;
    cout << "Second Largest = " << m2 << endl;
    return 0;
}
