#include <iostream>
using namespace std;
int main() {
    int n;
    cout << "enter no: ";
    cin >> n;
    if (n <= 1) {
        cout << n << " not prime" << endl;
        return 0; }
  int  flag = 1;
    for (int i = 2; i * i <= n; i++) 
        if (n % i == 0) {
            flag=0;
            break;}
    if(flag==1)
        cout << n << "prime number.";
    else
        cout << n << "not prime number.";
    return 0;
}
