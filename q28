#include <iostream>
using namespace std;
int main() {
    int a[5];
   int e = 0, o = 0;
    cout << "Enter 5 numbers:\n";
    for(int i = 0; i < 5; i++) {
        cin >> a[i];
    }
    for(int i = 0; i < 5; i++) {
        if(a[i] % 2 == 0)
            e+= a[i];
        else
            o += a[i];
    }
    cout << "Sum of even numbers = " << e << endl;
    cout << "Sum of odd numbers = " << o << endl;
    return 0;
}
